msgid "Hello,"
msgstr "สวัสดี,"

#. js-lingui-explicit-id
#: src/emails/warn-suspended-workspace.email.tsx
msgid "It appears that your workspace <0>{workspaceDisplayName}</0> has been suspended for {daysSinceInactive} days."
msgstr "ดูเหมือนว่า Workspace ทำงานของคุณ <0>{workspaceDisplayName}</0> ถูกระงับเป็นเวลา {daysSinceInactive} วัน"

#. js-lingui-explicit-id
#: src/emails/warn-suspended-workspace.email.tsx
msgid "The workspace will be deactivated in {remainingDays} {dayOrDays}, and all its data will be deleted."
msgstr "Workspace จะถูกปิดใช้งานในอีก {remainingDays} {dayOrDays} และข้อมูลทั้งหมดจะถูกลบ"

#. js-lingui-explicit-id
#: src/emails/warn-suspended-workspace.email.tsx
msgid "If you wish to continue using Mobius, please update your subscription within the next {remainingDays} {dayOrDays}."
msgstr "หากคุณต้องการใช้งาน Mobius ต่อไป โปรดอัปเดตการสมัครสมาชิกของคุณภายใน {remainingDays} {dayOrDays} ข้างหน้า"

#. js-lingui-explicit-id
#: src/emails/warn-suspended-workspace.email.tsx
msgid "Update your subscription"
msgstr "อัปเดตการสมัครสมาชิกของคุณ"

